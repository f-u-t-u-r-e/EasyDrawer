# LLM configuration
ANTHROPIC_API_KEY=your_llm_api_key_here

# Image generation backend: sd | flux
IMAGE_BACKEND=flux

# Stable Diffusion API configuration (only needed when IMAGE_BACKEND=sd)
SD_API_URL=http://localhost:7860
SD_API_KEY=

# BFL FLUX API configuration
FLUX_API_URL=https://api.bfl.ai/v1
FLUX_API_KEY=your_bfl_api_key_here
FLUX_MODEL_ENDPOINT=flux-2-pro-preview
FLUX_OUTPUT_FORMAT=jpeg
FLUX_SAFETY_TOLERANCE=2
FLUX_DISABLE_PUP=false
FLUX_POLL_TIMEOUT=120

# Generation parameters
SD_BATCH_SIZE=3
FLUX_BATCH_SIZE=3
MAX_REFINEMENT_ROUNDS=2
QUALITY_THRESHOLD=75.0

# CLIP scoring model
CLIP_MODEL_NAME=ViT-L-14
CLIP_PRETRAINED=openai

# App configuration
DEBUG=true
LOG_LEVEL=INFO
